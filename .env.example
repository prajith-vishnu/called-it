# ============================================================================
# Copy this file to "server/.env" and fill in REAL values there.
# ".env" is git-ignored and must NEVER be committed. These are PLACEHOLDERS.
# In production, set these in your host's secret store, not a file.
# ============================================================================

# Your Groq API key (from https://console.groq.com/keys). Backend-only — never
# shipped to the browser. Treat it like a password; rotate it if it is exposed.
GROQ_API_KEY=your-groq-api-key-here

# Secret required for the admin endpoints (POST /api/refresh and
# POST /api/admin/resolve). Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_REFRESH_TOKEN=generate-a-long-random-token-here

# ── optional: model / pipeline tuning ───────────────────────────────────────
#   GROQ_MODEL                 generation model (default llama-3.3-70b-versatile)
#   GROQ_COMPOUND_MODEL        web-search resolver (default groq/compound)
#   GROQ_WEB_RESOLUTION        "off" to disable web-search resolution
#   GROQ_MAX_CALLS_PER_DAY     hard local cap on Groq calls/day (default 40 —
#                              <5% of the free tier, on top of the header guard)
#   REFRESH_MIN_INTERVAL_HOURS min hours between refresh runs (default 3)
#   SCHEDULER_ENABLED          "0" to disable the in-process refresh scheduler
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_COMPOUND_MODEL=groq/compound
# GROQ_WEB_RESOLUTION=on
# GROQ_MAX_CALLS_PER_DAY=40
# REFRESH_MIN_INTERVAL_HOURS=3
# SCHEDULER_ENABLED=1

# ── optional: deployment ────────────────────────────────────────────────────
# Strict CORS — the ONLY cross-origin allowed to read the API. Set this to your
# GitHub Pages origin if the front-end is hosted separately from the backend.
# Leave unset for same-origin only (no cross-origin reads).
# ALLOWED_ORIGIN=https://yourname.github.io

# Set NODE_ENV=production (or COOKIE_SECURE=1) when deployed behind HTTPS so
# session cookies get the Secure flag. TRUST_PROXY=1 only if behind a reverse
# proxy that sets x-forwarded-for (rate limiting uses the client IP).
# NODE_ENV=production
# COOKIE_SECURE=1
# TRUST_PROXY=1

# Port (default 3000).
# PORT=3000

# NOTE: Accounts are username + password only — no email, no Supabase, no
# third-party auth keys. Passwords are scrypt-hashed; sessions are opaque
# httpOnly cookies. The user store lives in server/data/db.json (git-ignored).
# There are NO secrets in this example file — keep it that way.
