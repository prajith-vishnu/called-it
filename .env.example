# ============================================================================
# Copy this file to ".env" and fill in REAL values there.
# ".env" is git-ignored and must NEVER be committed. These are PLACEHOLDERS.
# In production, set these in your host's secret store, not a file.
# ============================================================================

# Your Groq API key (from https://console.groq.com/keys). Backend-only — never
# shipped to the browser. Treat it like a password; rotate it if it is exposed.
GROQ_API_KEY=your-groq-api-key-here

# Optional: model overrides.
#   GROQ_MODEL          generation model (default llama-3.3-70b-versatile)
#   GROQ_COMPOUND_MODEL web-search resolver (default groq/compound)
#   GROQ_WEB_RESOLUTION set to "off" to disable web-search resolution entirely
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_COMPOUND_MODEL=groq/compound
# GROQ_WEB_RESOLUTION=on

# Secret required to trigger POST /api/refresh (only if you expose the HTTP
# endpoint; the cron/CLI path doesn't need it). Generate a long random value:
# e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_REFRESH_TOKEN=generate-a-long-random-token-here

# Optional: strict CORS — the ONLY cross-origin allowed to read predictions.
# Set this to your GitHub Pages origin if the front-end is hosted separately.
# Leave unset for same-origin only (no cross-origin reads).
# ALLOWED_ORIGIN=https://yourname.github.io

# Optional: port (default 3000).
# PORT=3000

# NOTE: There are NO accounts and NO database. No Supabase, no auth keys, no
# personal data. All per-user game state lives in the browser's localStorage.
